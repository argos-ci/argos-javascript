{
  "name": "@argos-ci/cli",
  "description": "Command-line (CLI) for visual testing with Argos.",
  "version": "6.4.1",
  "bin": {
    "argos": "./bin/argos-cli.js"
  },
  "type": "module",
  "exports": {
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/argos-ci/argos-javascript.git",
    "directory": "packages/core"
  },
  "homepage": "https://argos-ci.com/docs/reference/argos-command-line-interface-cli",
  "bugs": {
    "url": "https://github.com/argos-ci/argos-javascript/issues"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "license": "MIT",
  "keywords": [
    "cli",
    "argos",
    "testing",
    "visual testing",
    "regression",
    "visual regression"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@argos-ci/api-client": "workspace:*",
    "@argos-ci/core": "workspace:*",
    "commander": "^15.0.0",
    "open": "^11.0.0",
    "ora": "^9.4.0",
    "update-notifier": "^7.3.1"
  },
  "devDependencies": {
    "vitest": "catalog:"
  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest run src",
    "e2e": "vitest e2e --tags-filter=\"not oidc and not tokenless\"",
    "e2e-oidc": "vitest e2e/upload-oidc.test.ts",
    "e2e-tokenless": "vitest e2e/upload-tokenless.test.ts",
    "check-types": "tsc",
    "check-format": "prettier --check --ignore-unknown --ignore-path=../../.gitignore --ignore-path=../../.prettierignore .",
    "lint": "eslint ."
  }
}
