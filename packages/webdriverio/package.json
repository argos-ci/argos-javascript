{
  "name": "@argos-ci/webdriverio",
  "description": "WebdriverIO SDK for visual testing with Argos.",
  "version": "0.7.0",
  "author": "Smooth Code",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/argos-ci/argos-javascript.git",
    "directory": "packages/webdriverio"
  },
  "homepage": "https://argos-ci.com/docs/webdriverio",
  "bugs": {
    "url": "https://github.com/argos-ci/argos-javascript/issues"
  },
  "keywords": [
    "webdriverio",
    "webdriverio-plugin",
    "argos",
    "testing",
    "visual testing",
    "regression",
    "visual regression"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "peerDependencies": {
    "webdriverio": "^6 || ^7 || ^8 || ^9"
  },
  "dependencies": {
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@argos-ci/cli": "workspace:*",
    "@wdio/cli": "^9.27.1",
    "@wdio/globals": "^9.27.1",
    "@wdio/local-runner": "^9.27.1",
    "@wdio/mocha-framework": "^9.27.1",
    "@wdio/spec-reporter": "^9.27.1",
    "@wdio/types": "^9.27.1",
    "tsx": "^4.21.0",
    "webdriverio": "^9.27.1"
  },
  "scripts": {
    "build": "tsdown && cp ./src/index.cjs ./dist",
    "test-e2e": "wdio run ./wdio.conf.ts",
    "argos-upload": "pnpm exec argos upload screenshots --build-name \"argos-webdriverio-e2e-node-$NODE_VERSION-$OS\"",
    "e2e": "pnpm run test-e2e && pnpm run argos-upload",
    "check-types": "tsc",
    "check-format": "prettier --check --ignore-unknown --ignore-path=../../.gitignore --ignore-path=../../.prettierignore .",
    "lint": "eslint ."
  }
}
